rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // C/S 요청 첨부파일: 로그인한 사용자만 자신의 폴더에 업로드/다운로드
    match /customerservice/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // 전달사항(공지) 첨부파일: 로그인한 사용자만 자신의 폴더에 업로드/다운로드
    match /announcements/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
